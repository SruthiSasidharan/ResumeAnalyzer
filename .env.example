# Copy this file to .env in the project root (same folder as manage.py).
# Django loads .env via python-dotenv before reading ADZUNA_* and DB_* below.

# Database - MySQL (default)
DB_ENGINE=mysql
DB_NAME=career_guidance_db
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# For SQLite (no MySQL required):
# DB_ENGINE=sqlite

# Live job search (Adzuna — https://developer.adzuna.com/signup)
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# ADZUNA_COUNTRY=in
